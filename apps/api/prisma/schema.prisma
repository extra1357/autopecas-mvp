  iniciadoEm  DateTime?
  resolvidoEm DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  conversa Conversa @relation(fields: [conversaId], references: [id])

  @@map("atendimentos")
}

